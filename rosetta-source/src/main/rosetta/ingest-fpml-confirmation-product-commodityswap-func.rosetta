func MapFixedLegToFixedPricePayout:
    inputs:
        fpmlFixedLeg fpml.FixedLeg (0..1)
        cdmCounterpartyList Counterparty (0..2)
    output:
        payout Payout (0..1)

    set payout:
        Payout {
            FixedPricePayout:
                FixedPricePayout {
                    payerReceiver: MapPayerReceiver(
                                fpmlFixedLeg -> payerReceiverModel -> payerModel,
                                fpmlFixedLeg -> payerReceiverModel -> receiverModel,
                                cdmCounterpartyList
                            ),
                    priceQuantity:
                        ResolvablePriceQuantity {
                            quantitySchedule: MapCommodityNotionalQuantityToQuantityWithAddress(
                                        fpmlFixedLeg -> commodityNotionalQuantityModel -> commodityNotionalQuantityModelSequence,
                                        fpmlFixedLeg
                                    ),
                            ...
                        },
                    paymentDates: MapCommodityRelativePaymentDates(
                                fpmlFixedLeg -> commodityPaymentDatesModel -> relativePaymentDates
                            ),
                    fixedPrice:
                        FixedPrice {
                            price: MapCommodityFixedLegToPriceWithAddress(
                                        fpmlFixedLeg -> commodityFixedPriceModel -> commodityFixedPriceModelChoice,
                                        fpmlFixedLeg -> commodityFixedPriceModel -> fixedPriceSchedule,
                                        fpmlFixedLeg
                                    )
                        },
                    ...
                },
            ...
        }

func MapCommoditySwapPriceQuantityList:
    inputs:
        fpmlCommoditySwap fpml.CommoditySwap (0..1)
    output:
        priceQuantityList PriceQuantity (0..*)

    alias fpmlCommoditySwapLegList: fpmlCommoditySwap -> commoditySwapLeg

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.FixedLeg then MapFixedLegToPriceQuantity,
                    default empty

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.FloatingLeg then MapFloatingLegToPriceQuantity,
                    default empty

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.GasPhysicalLeg then MapGasPhysicalLegToPriceQuantity,
                    default empty

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.OilPhysicalLeg then MapOilPhysicalLegToPriceQuantity,
                    default empty

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.ElectricityPhysicalLeg then MapElectricityPhysicalLegToPriceQuantity,
                    default empty

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.EnvironmentalPhysicalLeg then MapEnvironmentalPhysicalLegToPriceQuantity,
                    default empty

    add priceQuantityList:
        fpmlCommoditySwapLegList
            extract
                item switch
                    fpml.CoalPhysicalLeg then MapCoalPhysicalLegToPriceQuantity,
                    default empty

func MapFixedLegToPriceQuantity:
    inputs:
        fpmlFixedLeg fpml.FixedLeg (0..1)
    output:
        priceQuantity PriceQuantity (0..1)

    set priceQuantity:
        PriceQuantity {
            quantity: MapCommodityNotionalQuantityToQuantityListWithLocation(
                        fpmlFixedLeg -> commodityNotionalQuantityModel -> commodityNotionalQuantityModelSequence,
                        fpmlFixedLeg
                    ),
            price: MapCommodityFixedLegToPriceWithLocation(
                        fpmlFixedLeg -> commodityFixedPriceModel -> commodityFixedPriceModelChoice,
                        fpmlFixedLeg -> commodityFixedPriceModel -> fixedPriceSchedule,
                        fpmlFixedLeg
                    ),
            ...
        }

func MapFloatingLegToPriceQuantity:
    inputs:
        fpmlFloatingLeg fpml.FloatingLeg (0..1)
    output:
        priceQuantity PriceQuantity (0..1)

    alias priceCapacityUnit:
        // if fpmlFloatingLeg exists then
        MapCapacityUnitEnum(fpmlFloatingLeg -> notionalQuantity -> quantityUnit -> value)

    set priceQuantity:
        PriceQuantity {
            quantity: MapCommodityNotionalQuantityToQuantityListWithLocation(
                        fpmlFloatingLeg -> commodityNotionalQuantityModel -> commodityNotionalQuantityModelSequence,
                        fpmlFloatingLeg
                    ),
            observable: MapAssetToObservableWithLocation(fpmlFloatingLeg -> commodity),
            price: MapCommoditySpreadToPriceWithLocation(
                        fpmlFloatingLeg -> calculation -> spread,
                        priceCapacityUnit,
                        fpmlFloatingLeg
                    ),
            ...
        }

