func MapRequestConfirmationToTradeState:
    inputs:
        fpmlRequestConfirmation fpml.RequestConfirmation (0..1)
    output:
        tradeState TradeState (0..1)

    alias fpmlTrade:
        GetFpmlTrade(
                fpmlRequestConfirmation -> tradingAndPostTradeEventsModel -> tradingEventsBaseModel -> tradePackage,
                fpmlRequestConfirmation -> tradingAndPostTradeEventsModel -> tradingEventsBaseModel -> tradingEventsBaseModelSequence,
                fpmlRequestConfirmation -> tradingAndPostTradeEventsModel -> postTradeEventsBaseModel -> postTradeEventsBaseModelSequence,
                fpmlRequestConfirmation -> tradingAndPostTradeEventsModel -> postTradeEventsBaseModel -> novation,
                empty,
                empty
            )

    set tradeState:
        MapTradeState(
                fpmlTrade,
