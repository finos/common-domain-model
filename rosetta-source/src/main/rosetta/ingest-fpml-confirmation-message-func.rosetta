namespace cdm.ingest.fpml.confirmation.message
version "${project.version}"

import cdm.event.common.*
import cdm.event.workflow.*
import cdm.ingest.fpml.confirmation.common.*
import cdm.ingest.fpml.confirmation.tradestate.*
import cdm.ingest.fpml.confirmation.workflowstep.*

import fpml.consolidated.* as fpml
import fpml.consolidated.confirmation.processes.* as fpml
import fpml.consolidated.doc.* as fpml
import fpml.consolidated.main.* as fpml

func Ingest_FpmlConfirmationToTradeState:
    [ingest XML]
    inputs:
        fpmlDocument fpml.Document (0..1)
    output:
        tradeState TradeState (0..1)

    set tradeState:
        fpmlDocument switch
            fpml.ConfirmationAgreed then MapConfirmationAgreedToTradeState,
            fpml.DataDocument then MapDataDocumentToTradeState,
            fpml.ExecutionNotification then MapExecutionNotificationToTradeState,
            fpml.RequestClearing then MapRequestClearingToTradeState,
            fpml.RequestConfirmation then MapRequestConfirmationToTradeState,
            default empty

func Ingest_FpmlConfirmationToWorkflowStep:
    [ingest XML]
    inputs:
        fpmlDocument fpml.Document (0..1)
    output:
        workflowStep WorkflowStep (0..1)

    set workflowStep:
        fpmlDocument switch
            fpml.ClearingConfirmed then MapClearingConfirmedToWorkflowStep,
            fpml.ExecutionAdvice then MapExecutionAdviceToWorkflowStep,
            fpml.ExecutionAdviceRetracted then MapExecutionAdviceRetractedToWorkflowStep,
            fpml.ExecutionNotification then MapExecutionNotificationToWorkflowStep,
            fpml.RequestClearing then MapRequestClearingToWorkflowStep,
            fpml.TradeChangeAdvice then MapTradeChangeAdviceToWorkflowStep,
            default empty

func MapConfirmationAgreedToTradeState:
    inputs:
        fpmlConfirmationAgreed fpml.ConfirmationAgreed (0..1)
    output:
        tradeState TradeState (0..1)

    alias fpmlTrade:
        GetFpmlTrade(
                fpmlConfirmationAgreed -> tradePackage,
                fpmlConfirmationAgreed -> trade,
                fpmlConfirmationAgreed -> novation,
                fpmlConfirmationAgreed -> termination,
                fpmlConfirmationAgreed -> amendment
            )

    set tradeState:
        MapTradeState(
                fpmlConfirmationAgreed -> trade,
                fpmlConfirmationAgreed -> party,
                fpmlConfirmationAgreed -> account,
                empty,
                empty
            )

func MapDataDocumentToTradeState:
    inputs:
        fpmlDataDocument fpml.DataDocument (0..1)
    output:
        tradeState TradeState (0..1)

    set tradeState:
        MapTradeState(
                fpmlDataDocument -> trade only-element,
                fpmlDataDocument -> party,
                fpmlDataDocument -> account,
                empty,
                empty
            )

func MapExecutionNotificationToTradeState:
    inputs:
        fpmlExecutionNotification fpml.ExecutionNotification (0..1)
    output:
        tradeState TradeState (0..1)

    alias fpmlTrade:
        GetFpmlTrade(
                fpmlExecutionNotification -> tradePackage,
                fpmlExecutionNotification -> trade,
                empty,
                empty,
                empty
            )

    set tradeState:
        MapTradeState(
                fpmlTrade,
                fpmlExecutionNotification -> party,
                fpmlExecutionNotification -> account,
                empty,
                empty
            )

func MapRequestClearingToTradeState:
