                                InterestRateIndex: MapFloatingRateIndexToRateOptionWithLocation(
                                            fpmlFloatingRateIndex,
                                            fpmlIndexTenor,
                                            fpmlLeg
                                        ),
                                ...
                            },
                        ...
                    },
                    CreateObservableKey(empty, fpmlLeg)
                )

