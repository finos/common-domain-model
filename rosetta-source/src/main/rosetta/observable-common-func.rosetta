namespace cdm.observable.common
version "${project.version}"

import cdm.base.datetime.*
import cdm.base.math.*
import cdm.base.staticdata.asset.common.*
import cdm.observable.asset.*

func ResolveTimeZoneFromTimeType: <"Defines inputs and outputs needed to derive the time and time-zone for a product identifier">
    [codeImplementation]
    inputs:
        assetIdentifier AssetIdentifier (1..1)
        timeType TimeTypeEnum (1..1)
        determinationMethod DeterminationMethodEnum (1..1)
    output:
        time TimeZone (1..1)

func PriceQuantityTriangulation: <"Checks the relationship between price, multiplier, notional and number of units, and validates the result of their product.">
    inputs:
        price PriceSchedule (0..*)
        quantity NonNegativeQuantitySchedule (0..*)
    output:
        success boolean (1..1)

    alias filteredPrice:
        price
            filter priceType = AssetPrice or priceType = ExchangeRate
            then only-element

    alias assetPrice: filteredPrice -> value

    alias notional:
        quantity
            filter unit = filteredPrice -> unit
            then only-element
            then value

    alias noOfUnits:
        quantity
            extract
                if multiplier exists and multiplier -> unit = filteredPrice -> perUnitOf
                then value * multiplier -> value
                else if unit = filteredPrice -> perUnitOf
                then value
            then only-element

    set success:
        if assetPrice exists and noOfUnits exists and notional exists
        then assetPrice * noOfUnits = notional
        else True
